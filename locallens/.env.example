# Copy this file to .env.local for local development
# Set these variables in your Vercel/Netlify dashboard for production

# App name displayed in User-Agent headers
VITE_APP_NAME=LocalLens

# Replace with your actual deployed domain after first deploy
# Example: LocalLens/1.0 (https://locallens.vercel.app)
VITE_NOMINATIM_USER_AGENT=LocalLens/1.0 (https://your-domain.com)
